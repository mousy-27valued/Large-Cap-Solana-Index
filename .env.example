# Optional display name for this deployment
SERVICE_NAME=Second Bundles Signal Sender

# Bundles WebSocket URL
BUNDLES_WS_URL=wss://bundles.trade/ws/agentic

# Private API key for the DIFFERENT Bundles agent
BUNDLES_API_KEY=

# Bundle address for the DIFFERENT Bundles agent
BUNDLE_ADDRESS=

# Different token addresses for this deployment.
# Separate addresses with commas or new lines.
TOKEN_ADDRESSES=

# Note attached to each candidate signal
NOTE=Candidate submitted from second Railway service

# Private password used to trigger /send and view /history
SEND_SECRET=

# Keep false unless signals should be submitted after every restart
AUTO_SEND_ON_START=false

# WebSocket acknowledgement timeout
REQUEST_TIMEOUT_MS=15000

# Number of recent submissions kept in memory
MAX_HISTORY_ENTRIES=100
